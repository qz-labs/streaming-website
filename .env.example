# TMDB API Configuration
# Get your API key from https://www.themoviedb.org/settings/api
TMDB_KEY=your_tmdb_api_key_here

# Site Configuration
SITE_NAME=StreamFlix
BASE_URL=/StreamingWebsite/public

# Cache Configuration
CACHE_TTL=3600

# Consumet API — self-hosted instance for anime HLS streaming
# Deploy free at Vercel: https://github.com/consumet/api.consumet.org
# Leave blank to disable Consumet (anime will fall back to VidSrc)
CONSUMET_URL=http://localhost:4444
M3U8_PROXY_URL=http://localhost:3030