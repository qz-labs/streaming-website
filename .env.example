# TMDB API Configuration
# Get your API key from https://www.themoviedb.org/settings/api
TMDB_KEY=your_tmdb_api_key_here

# MariaDB Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=streamingwebsite
DB_USER=root
DB_PASSWORD=your_db_password_here

# Default admin account (used only on first run if no admin exists in the database)
# ADMIN_PASSWORD must be set to a non-default value or the admin account will NOT be seeded.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_something_strong

# Site Configuration
SITE_NAME=StreamFlix
BASE_URL=/StreamingWebsite/public

# Cache Configuration
CACHE_TTL=3600

# cURL SSL - path to CA bundle (XAMPP on Windows only; leave empty on Linux/production)
CURL_CA_BUNDLE=C:/xampp/apache/bin/curl-ca-bundle.crt

# Consumet/HiAnime API - self-hosted instance for anime HLS streaming (port 4444)
# Leave blank to disable (anime will fall back to embed sources)
CONSUMET_URL=http://localhost:4444

# M3U8 proxy service (port 3030)
M3U8_PROXY_URL=http://localhost:3030

# CinePro stream extractor - movie/TV direct HLS extraction (port 3002)
CINEPRO_URL=http://localhost:3002

# VidSrc M3U8 extractor - legacy service (port 3031)
VIDSRC_EXTRACTOR_URL=http://localhost:3031



